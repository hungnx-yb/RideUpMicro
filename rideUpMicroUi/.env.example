# Microservice routing via API Gateway
VITE_API_GATEWAY_URL=http://localhost:8080
VITE_IDENTITY_SERVICE_PATH=/api/identity

# Optional legacy override (if set, this wins)
# VITE_API_BASE_URL=http://localhost:8080/api/identity

# Supabase storage (for rendering image URLs from object path)
# Option 1: provide public base URL directly
# VITE_SUPABASE_PUBLIC_BASE_URL=https://<project-ref>.supabase.co/storage/v1/object/public/<bucket-name>

# Option 2: provide URL + bucket (used when VITE_SUPABASE_PUBLIC_BASE_URL is not set)
# VITE_SUPABASE_URL=https://<project-ref>.supabase.co
# VITE_SUPABASE_BUCKET=Ride_Up_Micro
